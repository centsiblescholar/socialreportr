# =============================================================================
# CentsibleScholar Daily Digest — Environment Variables
# =============================================================================
# Copy this to .env.local for local development, or add to Vercel project
# settings (Settings > Environment Variables) for production.
# All variables are required unless marked (optional).
# =============================================================================

# -- Security -----------------------------------------------------------------
# Used to authenticate cron requests and manual triggers.
# Generate with: openssl rand -hex 32
CRON_SECRET=your-secret-here

# -- Feature Flags ------------------------------------------------------------
# Set any of these to "false" to disable that data source.
# Useful during initial setup when not all APIs are configured yet.
ENABLE_GOOGLE_ADS=true
ENABLE_META_ADS=true
ENABLE_GA4=true
ENABLE_STRIPE=true

# -- Google Service Account ---------------------------------------------------
# Used by BOTH Google Ads and GA4 fetchers.
# This is the full JSON key file from GCP, stringified.
# Get it from: GCP Console > IAM & Admin > Service Accounts > Keys > Add Key
# Then stringify: cat service-account.json | jq -c .
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# -- Google Ads ---------------------------------------------------------------
# Developer token: https://developers.google.com/google-ads/api/docs/get-started/dev-token
# Customer ID: Your Google Ads account ID (numbers only, no dashes)
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_CUSTOMER_ID=1234567890

# (optional) If your Google Ads is managed under a manager (MCC) account,
# set this to the manager account's customer ID
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=9876543210

# -- Meta Ads -----------------------------------------------------------------
# System User token: Meta Business Suite > Business Settings > System Users
# Ad Account ID: Must include the "act_" prefix
META_ACCESS_TOKEN=your-system-user-token
META_AD_ACCOUNT_ID=act_1234567890

# -- Google Analytics 4 -------------------------------------------------------
# Property ID: GA4 Admin > Property Settings > Property ID (numeric)
GA4_PROPERTY_ID=123456789

# -- Stripe -------------------------------------------------------------------
# Secret key from: Stripe Dashboard > Developers > API Keys
# Use sk_live_ for production, sk_test_ for testing
STRIPE_SECRET_KEY=sk_live_your-key-here

# -- Email (Resend) -----------------------------------------------------------
# API key from: https://resend.com/api-keys
# From email must be from a verified domain in Resend
# To email: comma-separated list of recipient addresses
RESEND_API_KEY=re_your-key-here
DIGEST_FROM_EMAIL=CentsibleScholar <briefing@centsiblescholar.com>
DIGEST_TO_EMAIL=robert@centsiblescholar.com

# -- App URL (optional) -------------------------------------------------------
# Used for links in the email footer
NEXT_PUBLIC_APP_URL=https://app.centsiblescholar.com
